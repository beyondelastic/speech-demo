# Voice Agent Interface - Environment Configuration

# Required: Microsoft Foundry Project Configuration
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-4o

# Optional: Azure Speech Services Configuration
# If not provided, will use multi-service account from PROJECT_ENDPOINT
SPEECH_KEY=your-speech-service-key
SPEECH_REGION=swedencentral

# Note: Create your actual .env file in the parent directory (/home/aullah/git/speech-demo/.env)
# The application looks for .env in the parent folder to share configuration across approaches
