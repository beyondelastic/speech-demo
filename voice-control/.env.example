# Azure OpenAI (direct, not via Foundry Agent)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=           # optional if using DefaultAzureCredential
MODEL_DEPLOYMENT=gpt-41-nano

# Azure Speech (or use PROJECT_ENDPOINT to auto-resolve)
SPEECH_KEY=
SPEECH_REGION=swedencentral

# Foundry project endpoint (for auto-resolving speech credentials)
PROJECT_ENDPOINT=https://your-project.services.ai.azure.com

# Device API URLs (default: localhost for local dev, override for tunnel/remote)
LIGHTS_API_URL=http://localhost:8932
VIDEO_API_URL=http://localhost:8933

# Wake word (text-based detection on STT output)
WAKE_WORD=computer
WAKE_WORD_ENABLED=true

# Silence detection timeout in ms (lower = faster, but may cut off slow speakers)
SILENCE_TIMEOUT_MS=300
