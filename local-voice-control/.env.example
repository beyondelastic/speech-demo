# Azure Speech (container or cloud — used for STT + TTS + wake word)
SPEECH_KEY=your-speech-key
SPEECH_REGION=swedencentral

# Point to local speech container (comment out to use cloud directly)
SPEECH_CONTAINER_HOST=ws://localhost:5000

# Foundry Local (OpenAI-compatible endpoint — started by foundry CLI or SDK web server)
FOUNDRY_LOCAL_ENDPOINT=http://localhost:5273/v1
MODEL_NAME=Phi-4-mini-instruct-generic-cpu:5

# Device API URLs
LIGHTS_API_URL=http://localhost:8932
VIDEO_API_URL=http://localhost:8933

# Wake word (text-based detection on STT output)
WAKE_WORD=computer
WAKE_WORD_ENABLED=true

# Silence detection timeout in ms
SILENCE_TIMEOUT_MS=300
